# Copy this to .env and fill in your local values.
# Compose picks this up automatically — never commit .env.

# Path to your local config dir (contains config.yml, cache.json, audit_state.db).
# Recommended: create a local/ folder in the project root and copy files from Unraid.
CONFIG_DIR=./local

# How often the scheduled runner loops (hours). Lower for local testing.
SCHEDULE_TIME=6

# Log verbosity: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
